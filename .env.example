# Configure tracking identifiers through deployment environment variables only.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_TAG_ID=
NEXT_PUBLIC_META_PIXEL_ID=
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
NEXT_PUBLIC_CLARITY_ID=

# Server-only Shopify Storefront catalog configuration.
SHOPIFY_STORE_DOMAIN=
SHOPIFY_STOREFRONT_PRIVATE_ACCESS_TOKEN=
SHOPIFY_API_VERSION=

# Server-only contact email configuration.
RESEND_API_KEY=
CONTACT_FROM_EMAIL=
CONTACT_TO_EMAIL=

# Shopify paid-order fulfillment notifications.
# Use the Shopify app client secret that signs webhook deliveries.
SHOPIFY_WEBHOOK_SECRET=
FULFILLMENT_FROM_EMAIL=
FULFILLMENT_TO_EMAIL=
